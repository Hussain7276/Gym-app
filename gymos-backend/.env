# ══════════════════════════════════════════════════
#  GymOS Backend — Environment Configuration
#  Copy to .env and fill in real values
# ══════════════════════════════════════════════════

# ── Application ──────────────────────────────────
APP_NAME=GymOS
APP_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=false
ENVIRONMENT=development

# ── Database ─────────────────────────────────────
# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://gymos_user:GymOS%4012345@localhost:5432/gymos_db
# Sync connection string for Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg2://gymos_user:GymOS%4012345@localhost:5432/gymos_db
# Pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── JWT Authentication ───────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=4a595ef0ee320e1143bd3ca67b5a0924a361eccf3b56827428341a2e0e62140b7a5dee87abc3fc04b8029c9a191c84901a8a068280df06d0bfe040a4891b7169
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# ── Pagination ───────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── Billing Defaults (seeded into DB, overridable) ─
DEFAULT_TAX_RATE=0.08
DEFAULT_LATE_FEE=15.00
DEFAULT_TRAINER_MULTIPLIER=1.0

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json